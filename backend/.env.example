GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
POSTGRES_URL=postgresql+asyncpg://agent_user:agent_pass@localhost:5432/agent_db
CHROMA_HOST=localhost
CHROMA_PORT=8000
HTW_EMAIL_ADDRESS=
HTW_EMAIL_PASSWORD=
HTW_IMAP_HOST=mail.htw-berlin.de
HTW_IMAP_PORT=993
# Optional: Moodle-Web-Services-Token (HTW). In Moodle unter
# Einstellungen → Sicherheitsschlüssel erstellen. Aktiviert die On-Demand-
# Indizierung von Kursmaterialien im Tutor-Chat.
MOODLE_TOKEN=
MOODLE_URL=https://moodle.htw-berlin.de
MOODLE_USER_ID=
# Optional: Adzuna (kostenloser Key auf developer.adzuna.com) für echte Stellensuche
# inkl. Gehalt + Ortsfilter (Berlin). Ohne Key nutzt der Career-Agent automatisch
# Arbeitnow (frei, ohne Key). LinkedIn/StepStone/Indeed werden als vorgefilterte
# Deep-Links eingebunden (kein API/Scraping nötig).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOB_LOCATION=Berlin
# Nur Werkstudentenstellen anzeigen (Standard true, da App für Studierende).
# Auf false setzen, um alle Stellen zu sehen.
JOB_STUDENT_ONLY=true
